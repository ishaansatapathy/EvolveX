# Evolvex — copy to .env and fill in values

# Server
PORT=8000
BASE_URL=http://localhost:8000
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000
NODE_ENV=development
NEXT_PUBLIC_API_URL=/trpc

# Database (run: pnpm db:up && pnpm db:migrate)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/evolvex

# Auth — JWT (generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=change-me-min-32-chars-base64!!
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars!!

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api-auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# Email via Brevo (optional)
# BREVO_API_KEY=
# EMAIL_FROM=Evolvex <noreply@yourdomain.com>
# EMAIL_SENDER_NAME=Evolvex
# EMAIL_PROVIDER=brevo

# Turnstile bot protection (optional — Cloudflare dashboard)
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# SigNoz Cloud — https://signoz.io/docs/alerts-management/notification-channel/webhook/
# Cloud URL is your instance host, e.g. https://your-org.signoz.cloud
SIGNOZ_CLOUD_URL=
SIGNOZ_API_KEY=
# Ingestion (Settings → Ingestion) — required for production telemetry
SIGNOZ_INGESTION_URL=https://ingest.in2.signoz.cloud
SIGNOZ_INGESTION_KEY=
# Default service when alert labels omit service.name (metric alerts)
SIGNOZ_DEFAULT_SERVICE_NAME=payments-svc
# Dev-only fake traces when SigNoz returns zero matches (disabled when NODE_ENV=production)
SIGNOZ_DEMO_TRACES=true
# Production load generator tuning (pnpm signoz:loadgen)
SIGNOZ_LOAD_BASELINE_MS=8000
SIGNOZ_LOAD_SPIKE_MS=90000
SIGNOZ_LOAD_BASELINE_TRACES=2
SIGNOZ_LOAD_SPIKE_ERRORS=5
SIGNOZ_LOAD_SPIKE_METRIC=12
SIGNOZ_LOAD_BASELINE_FAST=8
SIGNOZ_LOAD_SPIKE_TAIL=2
SIGNOZ_LOAD_SPIKE_TAIL_MS=4800
# Slow trace threshold when investigating p95/p99 alerts (Evolvex pulls from SigNoz, does not compute percentiles)
SIGNOZ_SLOW_TRACE_MS=800
# In SigNoz create alert: latency p99 > 800ms for service.name = payments-svc → webhook to Evolvex
# Webhook hardening
SIGNOZ_WEBHOOK_SECRET=
SIGNOZ_WEBHOOK_RATE_LIMIT=120
# Investigation owner for webhook-created cases (must match your Google login email)
INVESTIGATION_OWNER_EMAIL=
# Optional explicit user UUID override
# INVESTIGATION_OWNER_USER_ID=
# GitHub push webhook → DEPLOY timeline (X-Hub-Signature-256 in production)
GITHUB_WEBHOOK_SECRET=
# Kubernetes event exporter / ArgoCD webhook
KUBERNETES_WEBHOOK_SECRET=
# eBPF collector (Cilium Hubble, Pixie, custom agent)
EBPF_WEBHOOK_SECRET=
# OpenAI — investigation LLM summaries
OPENAI_API_KEY=
# Demo login for judges (disable in production unless needed)
# DEMO_LOGIN_ENABLED=true
# DEMO_USER_EMAIL=demo@evolvex.dev
# DEMO_USER_PASSWORD=DemoPass123!

# OpenTelemetry self-instrumentation (API → SigNoz ingest)
# OTEL_SERVICE_NAME=evolvex-api
# OTEL_SDK_DISABLED=true
# Local dev: expose API with localtunnel (pnpm dev on :8000 must be running)
# LOCALTUNNEL_URL=https://your-subdomain.loca.lt
# SIGNOZ_WEBHOOK_PUBLIC_URL=https://your-subdomain.loca.lt/webhooks/signoz
# GitHub webhook URL: https://your-subdomain.loca.lt/webhooks/github
# Production example:
# SIGNOZ_WEBHOOK_PUBLIC_URL=https://evolvex-api.up.railway.app/webhooks/signoz

SKIP_ENV_VALIDATION=true
