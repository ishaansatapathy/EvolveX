# Evolvex — production environment (Railway API + Vercel Web)
# Copy values from local .env; replace URLs with production domains.

NODE_ENV=production
PORT=8000

# ── Replace with production URLs after deploy ──
BASE_URL=https://your-api.up.railway.app
CLIENT_URL=https://your-app.vercel.app
API_INTERNAL_URL=https://your-api.up.railway.app
NEXT_PUBLIC_API_URL=/trpc

# ── Database (Neon Postgres — recommended) ──
# Pooled URL for API runtime (Railway/Vercel env):
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct URL for migrations (Railway build + local pnpm db:migrate):
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# ── Auth ──
JWT_SECRET=
JWT_REFRESH_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-app.vercel.app/api-auth/google/callback

# ── SigNoz ──
SIGNOZ_CLOUD_URL=
SIGNOZ_API_KEY=
SIGNOZ_INGESTION_URL=https://ingest.in2.signoz.cloud
SIGNOZ_INGESTION_KEY=
SIGNOZ_DEFAULT_SERVICE_NAME=payments-svc
SIGNOZ_WEBHOOK_SECRET=
SIGNOZ_WEBHOOK_PUBLIC_URL=https://your-api.up.railway.app/webhooks/signoz

# ── OpenAI ──
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── GitHub ──
GITHUB_WEBHOOK_SECRET=
GITHUB_TOKEN=
INVESTIGATION_OWNER_EMAIL=

# ── K8s / eBPF webhooks ──
KUBERNETES_WEBHOOK_SECRET=
EBPF_WEBHOOK_SECRET=

# ── Optional OBI bridge (if running separately) ──
# OBI_BRIDGE_INTERVAL_SEC=60

# Production: do NOT skip validation
SKIP_ENV_VALIDATION=false
